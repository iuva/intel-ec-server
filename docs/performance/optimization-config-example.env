# 性能优化配置示例
# 用于解决 500 并发压测中的性能瓶颈

# ============================================
# 网关服务配置优化
# ============================================

# HTTP 客户端连接池配置（关键优化）
# 从默认 100 增加到 500，支持 500 并发
HTTP_MAX_CONNECTIONS=500
HTTP_MAX_KEEPALIVE_CONNECTIONS=200

# HTTP 客户端超时配置
# 从默认 15s 增加到 30s，给后端更多处理时间
HTTP_TIMEOUT=30.0
HTTP_CONNECT_TIMEOUT=10.0

# HTTP 客户端重试配置
# 启用重试机制，提高请求成功率
HTTP_MAX_RETRIES=2
HTTP_RETRY_DELAY=0.5

# ============================================
# 数据库连接池配置优化
# ============================================

# 数据库连接池大小（关键优化）
# 从默认 50 增加到 100，最大连接数 = 100 + 200 = 300
DB_POOL_SIZE=100
DB_MAX_OVERFLOW=200

# 数据库连接超时配置
# 确保连接和查询有合理的超时限制
DB_POOL_TIMEOUT=30.0
DB_CONNECT_TIMEOUT=10

# ============================================
# 认证中间件配置优化
# ============================================

# 认证中间件超时配置
# 确保认证请求不会阻塞太久
AUTH_MIDDLEWARE_TIMEOUT=10.0
AUTH_MIDDLEWARE_CONNECT_TIMEOUT=5.0

# ============================================
# 健康检查配置优化
# ============================================

# 健康检查超时配置
# 快速失败，不影响正常请求
HEALTH_CHECK_TIMEOUT=5.0
HEALTH_CHECK_CONNECT_TIMEOUT=2.0

# ============================================
# 系统资源限制（如果使用 Docker）
# ============================================

# 增加文件描述符限制
# ulimit -n 65535

# Docker 资源限制示例
# deploy:
#   resources:
#     limits:
#       cpus: '2'
#       memory: 2G
#     reservations:
#       cpus: '1'
#       memory: 1G

# ============================================
# 使用说明
# ============================================

# 1. 将这些配置添加到 docker-compose.yml 的 environment 部分
# 2. 或者创建 .env 文件并引用
# 3. 重启服务使配置生效
# 4. 重新运行压测验证效果

# 示例 docker-compose.yml 配置：
#
# services:
#   gateway-service:
#     environment:
#       - HTTP_MAX_CONNECTIONS=500
#       - HTTP_MAX_KEEPALIVE_CONNECTIONS=200
#       - HTTP_TIMEOUT=30.0
#       - HTTP_MAX_RETRIES=2
#       - HTTP_RETRY_DELAY=0.5
#
#   host-service:
#     environment:
#       - DB_POOL_SIZE=100
#       - DB_MAX_OVERFLOW=200
#       - DB_POOL_TIMEOUT=30.0
#       - DB_CONNECT_TIMEOUT=10

