# ==========================================
# Intel EC 微服务项目环境变量配置示例
# ==========================================
#
# 使用说明：
# 1. 复制此文件为 .env: cp .env.example .env
# 2. 根据实际环境修改配置值
# 3. 生产环境请使用强密码和密钥
# 4. 不要将 .env 文件提交到版本控制系统
#
# ==========================================

# ==========================================
# Python 环境配置
# ==========================================
# 用于确保 pyright 和运行时都能正确找到 shared 模块
# 添加项目根目录到 Python 路径，这样可以直接 import shared.* 而不需要相对导入
# Windows 示例: PYTHONPATH=C:\Users\YourName\Projects\intel_ec_ms
# macOS/Linux 示例: PYTHONPATH=/Users/YourName/KiroProjects/intel_ec_ms
PYTHONPATH=/path/to/intel_ec_ms

# ==========================================
# 服务基础配置
# ==========================================
# 服务版本号（用于版本管理和兼容性检查）
SERVICE_VERSION=1.0.0

# 运行环境（development, testing, production）
ENVIRONMENT=development

# ==========================================
# 服务名称和端口配置
# ==========================================
# Gateway Service (API网关) - 统一入口，路由转发，负载均衡
GATEWAY_SERVICE_NAME=gateway-service
GATEWAY_SERVICE_PORT=8000
# GATEWAY_SERVICE_IP=172.20.0.100  # Docker 环境中的服务 IP（可选，自动检测）

# Auth Service (认证服务) - JWT 认证、OAuth 2.0、用户管理
AUTH_SERVICE_NAME=auth-service
AUTH_SERVICE_PORT=8001
# AUTH_SERVICE_IP=172.20.0.101  # Docker 环境中的服务 IP（可选，自动检测）

# Host Service (主机服务) - Host 管理、Agent 通信、WebSocket、实时监控
HOST_SERVICE_NAME=host-service
HOST_SERVICE_PORT=8003
# HOST_SERVICE_IP=172.20.0.103  # Docker 环境中的服务 IP（可选，自动检测）

# ==========================================
# 服务间通信配置
# ==========================================
# 服务映射配置：用于服务间 HTTP 调用
# Docker 环境: 使用服务名（如 auth-service, host-service）
# 本地开发: 使用 127.0.0.1
# 远程服务器: 使用服务器 IP 或域名
SERVICE_HOST_AUTH=127.0.0.1
SERVICE_HOST_HOST=127.0.0.1

# ==========================================
# 网关负载均衡配置
# ==========================================
# 本地多实例配置（用于本地开发测试多实例场景）
# 格式: IP:PORT,IP:PORT（多个实例用逗号分隔）
# 优先级: Nacos 服务发现 > 本地多实例配置 > 单个服务地址
HOST_SERVICE_INSTANCES=127.0.0.1:8003
# AUTH_SERVICE_INSTANCES=127.0.0.1:8001,127.0.0.1:8002

# 负载均衡策略
# round_robin: 轮询（默认），确保每个实例获得相等的请求量
# random: 随机选择实例
# weighted_random: 加权随机选择（需要 Nacos 配置实例权重）
LOAD_BALANCE_STRATEGY=round_robin

# ==========================================
# MariaDB 数据库配置
# ==========================================
# MariaDB 10.11 数据库连接配置
# 本地开发: 127.0.0.1
# Docker 环境: mariadb（容器名）
# 远程服务器: 服务器 IP 或域名
MARIADB_HOST=127.0.0.1
MARIADB_PORT=3306
MARIADB_USER=intel_user
MARIADB_PASSWORD=intel_***REMOVED***
MARIADB_DATABASE=intel_cw

# ==========================================
# MariaDB SSL/TLS 配置（可选）
# ==========================================
# 启用 SSL 加密连接
# true: 启用 SSL 加密传输
# false: 不使用 SSL（默认）
MARIADB_SSL_ENABLED=false

# SSL 证书配置（仅在 MARIADB_SSL_ENABLED=true 时生效）
# CA 证书文件路径（用于验证服务器证书）
# 生产环境建议提供 CA 证书以确保连接安全
MARIADB_SSL_CA=./infrastructure/mysql/ssl/ca-cert.pem

# 客户端证书文件路径（可选，如果服务器要求客户端证书认证）
MARIADB_SSL_CERT=./infrastructure/mysql/ssl/client-cert.pem
MARIADB_SSL_KEY=./infrastructure/mysql/ssl/client-key.pem

# SSL 验证选项
# 是否验证服务器证书
# true: 验证服务器证书（生产环境推荐）
# false: 不验证证书（开发/测试环境，仅提供加密传输）
MARIADB_SSL_VERIFY_CERT=true

# 是否验证服务器身份（主机名验证）
# true: 验证服务器主机名与证书匹配
# false: 不验证主机名（默认）
MARIADB_SSL_VERIFY_IDENTITY=false

# ==========================================
# Redis 缓存配置
# ==========================================
# Redis 缓存连接配置
# 本地开发: 127.0.0.1
# Docker 环境: redis（容器名）
# 远程服务器: 服务器 IP 或域名
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_USERNAME=

# ==========================================
# Redis SSL/TLS 配置（可选）
# ==========================================
# 启用 SSL 加密连接
# true: 启用 SSL 加密传输（使用 rediss:// 协议）
# false: 不使用 SSL（默认，使用 redis:// 协议）
REDIS_SSL_ENABLED=false

# SSL 证书配置（仅在 REDIS_SSL_ENABLED=true 时生效）
# CA 证书文件路径（用于验证服务器证书）
# 生产环境建议提供 CA 证书以确保连接安全
REDIS_SSL_CA=./infrastructure/redis/ssl/ca-cert.pem

# 客户端证书文件路径（可选，如果服务器要求客户端证书认证）
REDIS_SSL_CERT=./infrastructure/redis/ssl/client-cert.pem
REDIS_SSL_KEY=./infrastructure/redis/ssl/client-key.pem

# SSL 验证选项
# 是否验证服务器证书
# none: 不验证证书（开发/测试环境，仅提供加密传输）
# optional: 可选验证
# required: 验证服务器证书（生产环境推荐）
REDIS_SSL_VERIFY_CERT=none

# 是否验证服务器身份（主机名验证）
# true: 验证服务器主机名与证书匹配
# false: 不验证主机名（默认）
REDIS_SSL_VERIFY_IDENTITY=false


# ==========================================
# Nacos 服务发现配置
# ==========================================
# Nacos 服务器地址和认证信息
# 本地开发: http://127.0.0.1:8848
# Docker 环境: http://nacos:8848 或 http://172.20.0.12:8848
NACOS_SERVER_ADDR=http://localhost:8848
NACOS_PORT=8848
NACOS_USERNAME=nacos
NACOS_PASSWORD=nacos

# Nacos 命名空间和分组配置
NACOS_NAMESPACE=public
NACOS_GROUP=DEFAULT_GROUP

# Nacos 认证 Token（Base64 编码的 32 字节密钥，可选）
# NACOS_AUTH_TOKEN=VGhpc0lzQVNlY3JldEtleUZvck5hY29zQXV0aEF0TGVhc3QzMkJ5dGVz

# ==========================================
# JWT 认证配置
# ==========================================
# JWT 密钥和令牌配置
# 注意：生产环境必须使用强密钥，建议至少 32 字符
JWT_SECRET_KEY=your-secret-key-change-this-in-production
JWT_ALGORITHM=HS256

# JWT 令牌过期时间配置
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# ==========================================
# AES 加密配置
# ==========================================
# AES-256 加密密钥（用于主机密码等敏感数据加密）
# 注意：生产环境必须使用 32 字节密钥
# 如果密钥长度不足，系统会自动使用 PBKDF2 派生
AES_ENCRYPTION_KEY=your_secure_32_byte_key_here_1234567890123456

# ==========================================
# Jaeger 分布式追踪配置
# ==========================================
# Jaeger 追踪端点配置
# gRPC 端点（推荐，性能更好）
# 本地开发: 127.0.0.1:4317
# Docker 环境: jaeger:4317
JAEGER_ENDPOINT_HOST=jaeger:4317

# HTTP 端点（备用）
# 本地开发: http://localhost:14268/api/traces
# Docker 环境: http://jaeger:14268/api/traces
JAEGER_ENDPOINT=http://localhost:14268/api/traces

# ==========================================
# Prometheus 监控配置
# ==========================================
# Prometheus Push Gateway 地址（用于推送指标）
# 本地开发: http://localhost:9091
# Docker 环境: http://prometheus:9091
PROMETHEUS_PUSH_GATEWAY=http://localhost:9091

# ==========================================
# 外部服务 API 配置
# ==========================================
# 硬件服务 API 地址
# 用于主机硬件配置同步的外部服务
HARDWARE_API_URL=http://localhost:8080

# ==========================================
# 日志配置
# ==========================================
# 日志级别（DEBUG, INFO, WARNING, ERROR, CRITICAL）
LOG_LEVEL=INFO

# ==========================================
# 文件上传配置
# ==========================================
# 文件上传目录
# Windows 示例: C:\Users\YourName\Downloads\uploads
# macOS/Linux 示例: /Users/YourName/Downloads/uploads
FILE_UPLOAD_DIR=./uploads

# ==========================================
# 组件开关配置
# ==========================================
# 这些开关控制是否启用相应的组件功能
# 本地开发环境可以关闭部分组件以提高启动速度

# Nacos 服务发现开关
# true: 启用 Nacos 服务发现和注册
# false: 禁用 Nacos（使用静态配置或本地多实例配置）
ENABLE_NACOS=false

# Jaeger 分布式追踪开关
# true: 启用 Jaeger 分布式追踪
# false: 禁用 Jaeger（提高性能，减少开销）
ENABLE_JAEGER=false

# Prometheus 监控指标开关
# true: 启用 Prometheus 指标收集
# false: 禁用 Prometheus（减少性能开销）
ENABLE_PROMETHEUS=false

# ==========================================
# 硬件接口 Mock 配置
# ==========================================
# 是否使用 Mock 硬件接口（开发/测试环境）
# true: 使用 Mock 数据，不调用真实硬件接口
# false: 调用真实硬件接口
USE_HARDWARE_MOCK=true

# ==========================================
# 邮箱配置（SMTP）
# ==========================================
# 用于发送通知邮件（如主机审批通知）
# SMTP 服务器配置
SMTP_SERVER=smtp.example.com
SMTP_PORT=25
# SMTP_PORT=587  # TLS/STARTTLS 端口
# SMTP_PORT=465  # SSL 端口

# SMTP 认证信息
SMTP_USER=your_email@example.com
SMTP_PASSWORD=your_email_***REMOVED***word

# 发件人邮箱地址
SMTP_FROM_EMAIL=your_email@example.com

# ==========================================
# 服务实例 ID（可选）
# ==========================================
# 每个服务实例的唯一标识（用于 WebSocket 跨实例通信）
# 如果不设置，系统会自动生成（服务名+随机后缀）
# SERVICE_INSTANCE_ID=host-service-instance-1

# ==========================================
# 数据库连接池配置（高级配置，可选）
# ==========================================
# 数据库连接池大小（默认由服务配置决定）
# DB_POOL_SIZE=300
# DB_MAX_OVERFLOW=500

# ==========================================
# HTTP 客户端配置（高级配置，可选）
# ==========================================
# HTTP 请求超时配置（秒）
# HTTP_TIMEOUT=15.0
# HTTP_CONNECT_TIMEOUT=5.0
# HTTP_MAX_KEEPALIVE_CONNECTIONS=20
# HTTP_MAX_CONNECTIONS=100

# ==========================================
# 健康检查配置（高级配置，可选）
# ==========================================
# 健康检查超时配置（秒）
# HEALTH_CHECK_TIMEOUT=5.0
# HEALTH_CHECK_CONNECT_TIMEOUT=2.0
