# ========== 项目根目录配置 ==========
# PYTHONPATH 用于 Python 模块导入
# 改为你实际的项目根目录路径
PYTHONPATH=/Users/chiyeming/KiroProjects/intel_ec_ms

# ========== 应用环境配置 ==========
# 应用环境：development（开发）/ staging（预发布）/ production（生产）
ENVIRONMENT=development

# 日志级别：DEBUG / INFO / WARNING / ERROR / CRITICAL
LOG_LEVEL=INFO

# ========== MariaDB 数据库配置 ==========
# 数据库主机地址
# 本地开发：127.0.0.1
# Docker 环境：mariadb（容器名称）
MARIADB_HOST=127.0.0.1

# 数据库端口
MARIADB_PORT=3306

# 数据库用户名
MARIADB_USER=intel_user

# 数据库密码
MARIADB_PASSWORD=intel_***REMOVED***

# 数据库名称
MARIADB_DATABASE=intel_cw

# ========== Redis 缓存配置 ==========
# Redis 主机地址
# 本地开发：127.0.0.1
# Docker 环境：redis（容器名称）
REDIS_HOST=127.0.0.1

# Redis 端口
REDIS_PORT=6379

# Redis 密码（如果有）
# 默认为空
REDIS_PASSWORD=

# Redis 数据库编号
REDIS_DB=0

# ========== Nacos 服务发现配置 ==========
# Nacos 服务器地址
# 本地开发：http://localhost:8848
# Docker 环境：http://intel-nacos:8848
NACOS_SERVER_ADDR=http://localhost:8848

# Nacos 命名空间
NACOS_NAMESPACE=public

# Nacos 分组
NACOS_GROUP=DEFAULT_GROUP

# Nacos 认证用户名
NACOS_USERNAME=nacos

# Nacos 认证密码
NACOS_PASSWORD=nacos

# ========== Jaeger 分布式追踪配置 ==========
# Jaeger Collector OTLP HTTP 端点
# 本地开发：http://localhost:4318
# Docker 环境：http://intel-jaeger:4318
JAEGER_ENDPOINT=http://localhost:4318

# Jaeger 采样率（0.0-1.0）
# 0.0 = 不采样
# 1.0 = 全量采样
JAEGER_SAMPLING_RATE=1.0

# ========== Prometheus 监控配置 ==========
# Prometheus 服务器地址
PROMETHEUS_URL=http://localhost:9090

# ========== Grafana 监控配置 ==========
# Grafana 服务器地址
GRAFANA_URL=http://localhost:3000

# Grafana 管理员用户名
GRAFANA_USERNAME=admin

# Grafana 管理员密码
GRAFANA_PASSWORD=***REMOVED***

# ========== JWT 认证配置 ==========
# JWT 密钥（用于签名 JWT 令牌）
# 必须至少 32 个字符
JWT_SECRET_KEY=your-super-secret-jwt-key-here-change-in-production

# JWT 访问令牌过期时间（分钟）
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30

# JWT 刷新令牌过期时间（天）
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# ========== 服务配置 ==========
# 网关服务
GATEWAY_SERVICE_PORT=8000
GATEWAY_SERVICE_HOST=0.0.0.0

# 认证服务
AUTH_SERVICE_PORT=8001
AUTH_SERVICE_HOST=0.0.0.0

# 管理服务
ADMIN_SERVICE_PORT=8002
ADMIN_SERVICE_HOST=0.0.0.0

# 主机服务
HOST_SERVICE_PORT=8003
HOST_SERVICE_HOST=0.0.0.0

# ========== 其他配置 ==========
# 允许的 CORS 源
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8000,http://localhost:8001,http://localhost:8002,http://localhost:8003

# API 版本
API_VERSION=v1

# 时区
TZ=Asia/Shanghai
