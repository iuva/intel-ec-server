# ==========================================
# Intel EC Microservices Project Environment Variables Configuration Example
# ==========================================
# 
# Usage Instructions:
# 1. Copy this file as .env: cp .env.example .env
# 2. Modify configuration values according to the actual environment
# 3. Use strong ***REMOVED***words and keys in production environments
# 4. Do not commit .env file to version control systems
# 
# ==========================================

# ==========================================
# 基础环境配置 (Basic Environment)
# ==========================================
# Python Path (for finding modules)
PYTHONPATH=/path/to/intel_ec_ms
SERVICE_VERSION=1.0.0
# Environment: development, testing, production
ENVIRONMENT=development
LOG_LEVEL=INFO

# ==========================================
# 服务定义配置 (Service Definitions)
# ==========================================
# Gateway Service
GATEWAY_SERVICE_NAME=gateway-service
GATEWAY_SERVICE_PORT=8000
GATEWAY_SERVICE_IP=127.0.0.1  # Or container name in Docker

# Auth Service
AUTH_SERVICE_NAME=auth-service
AUTH_SERVICE_PORT=8001
AUTH_SERVICE_IP=127.0.0.1

# Host Service
HOST_SERVICE_NAME=host-service
HOST_SERVICE_PORT=8003
HOST_SERVICE_IP=127.0.0.1

# ==========================================
# 服务发现与通信 (Service Discovery & Communication)
# ==========================================
# Downstream Service Hosts (Gateway -> Service)
SERVICE_HOST_AUTH=127.0.0.1
SERVICE_HOST_HOST=127.0.0.1

# Load Balancing Strategy: round_robin, random, weighted_random
LOAD_BALANCE_STRATEGY=round_robin

# Local Multi-instance Debug Configuration (Optional)
# AUTH_SERVICE_INSTANCES=127.0.0.1:8001,127.0.0.1:8002
# HOST_SERVICE_INSTANCES=127.0.0.1:8003,127.0.0.1:8004

# Nacos Configuration (Default: disabled for local dev)
ENABLE_NACOS=false
NACOS_SERVER_ADDR=http://localhost:8848
NACOS_USERNAME=nacos
NACOS_PASSWORD=nacos
NACOS_NAMESPACE=public
NACOS_GROUP=DEFAULT_GROUP

# ==========================================
# 数据库配置 (Database - MariaDB)
# ==========================================
MARIADB_HOST=127.0.0.1
MARIADB_PORT=3306
MARIADB_USER=intel_user
MARIADB_PASSWORD=intel_***REMOVED***
MARIADB_DATABASE=intel_cw
MARIADB_SSL_ENABLED=false
MARIADB_SSL_VERIFY_CERT=false
MARIADB_SSL_CA=
MARIADB_SSL_CERT=
MARIADB_SSL_KEY=

# ==========================================
# 缓存配置 (Cache - Redis)
# ==========================================
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_SSL_ENABLED=false
REDIS_SSL_VERIFY_CERT=none
REDIS_SSL_VERIFY_IDENTITY=false

# ==========================================
# 安全配置 (Security - JWT & Encryption)
# ==========================================
# JWT
# Note: Use a strong secret key (at least 32 chars) in production
JWT_SECRET_KEY=your-secret-key-change-this-in-production
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# AES Encryption (for sensitive data)
# Note: Must be 32 bytes for AES-256
AES_ENCRYPTION_KEY=your_secure_32_byte_key_here_1234567890123456

# ==========================================
# HTTP 客户端配置 (HTTP Client Settings)
# ==========================================
# General HTTP Client
HTTP_TIMEOUT=15.0
HTTP_CONNECT_TIMEOUT=5.0
HTTP_MAX_KEEPALIVE_CONNECTIONS=20
HTTP_MAX_CONNECTIONS=100
HTTP_MAX_RETRIES=0
HTTP_RETRY_DELAY=0.0
HTTP_CLIENT_VERIFY_SSL=false

# Health Check Client
HEALTH_CHECK_TIMEOUT=5.0
HEALTH_CHECK_CONNECT_TIMEOUT=2.0
HEALTH_CHECK_MAX_KEEPALIVE_CONNECTIONS=5
HEALTH_CHECK_MAX_CONNECTIONS=10
HEALTH_CHECK_MAX_RETRIES=1
HEALTH_CHECK_RETRY_DELAY=0.0

# Auth Middleware Client
AUTH_MIDDLEWARE_TIMEOUT=10.0
AUTH_MIDDLEWARE_CONNECT_TIMEOUT=5.0

# WebSocket
WEBSOCKET_MAX_CONNECTIONS=1000

# ==========================================
# 监控与追踪 (Monitoring & Tracing)
# ==========================================
# Jaeger Distributed Tracing
ENABLE_JAEGER=false
JAEGER_ENDPOINT_HOST=127.0.0.1:4317
JAEGER_ENDPOINT=http://localhost:14268/api/traces

# Prometheus Metrics
ENABLE_PROMETHEUS=false
PROMETHEUS_PUSH_GATEWAY=http://localhost:9091

# ==========================================
# 业务功能配置 (Business Features)
# ==========================================
# Hardware Interface Mock (for development)
USE_HARDWARE_MOCK=true
HARDWARE_API_URL=http://localhost:8080

# File Upload Directory
FILE_UPLOAD_DIR=./uploads

# Cloud Storage / OSS (Optional)
OSS_ACCESS_KEY_ID=
OSS_ACCESS_KEY_SECRET=
OSS_ENDPOINT=
OSS_BUCKET_NAME=

# Email Service (SMTP)
SMTP_SERVER=smtp.example.com
SMTP_PORT=25 # or 587/465
SMTP_USER=your_email@example.com
SMTP_PASSWORD=your_email_***REMOVED***word
SMTP_FROM_EMAIL=your_email@example.com
