# ==========================================
# Intel EC Microservices Project Environment Variables Configuration Example
# ==========================================
#
# Usage Instructions:
# 1. Copy this file as .env: cp .env.example .env
# 2. Modify configuration values according to the actual environment
# 3. Use strong ***REMOVED***words and keys in production environments
# 4. Do not commit .env file to version control systems
#
# ==========================================

# ==========================================
# Python Environment Configuration
# ==========================================
# Used to ensure pyright and runtime can correctly locate shared modules
# Add project root directory to Python path, so shared.* can be imported directly without relative imports
# Windows Example: PYTHONPATH=C:\Users\YourName\Projects\intel_ec_ms
# macOS/Linux Example: PYTHONPATH=/Users/YourName/KiroProjects/intel_ec_ms
PYTHONPATH=/path/to/intel_ec_ms

# ==========================================
# Service Basic Configuration
# ==========================================
# Service Version (for version management and compatibility checking)
SERVICE_VERSION=1.0.0

# Runtime Environment (development, testing, production)
ENVIRONMENT=development

# ==========================================
# Service Names and Port Configuration
# ==========================================
# Gateway Service (API Gateway) - Unified entry, routing forwarding, load balancing
GATEWAY_SERVICE_NAME=gateway-service
GATEWAY_SERVICE_PORT=8000
# GATEWAY_SERVICE_IP=172.20.0.100  # Service IP in Docker environment (optional, auto-detection)

# Auth Service (Authentication Service) - JWT authentication, OAuth 2.0, user management
AUTH_SERVICE_NAME=auth-service
AUTH_SERVICE_PORT=8001
# AUTH_SERVICE_IP=172.20.0.101  # Service IP in Docker environment (optional, auto-detection)

# Host Service (Host Management Service) - Host management, Agent communication, WebSocket, real-time monitoring
HOST_SERVICE_NAME=host-service
HOST_SERVICE_PORT=8003
# HOST_SERVICE_IP=172.20.0.103  # Service IP in Docker environment (optional, auto-detection)

# ==========================================
# Inter-service Communication Configuration
# ==========================================
# Service mapping configuration: for inter-service HTTP calls
# Docker Environment: Use service names (e.g., auth-service, host-service)
# Local Development: Use 127.0.0.1
# Remote Server: Use server IP or domain name
SERVICE_HOST_AUTH=127.0.0.1
SERVICE_HOST_HOST=127.0.0.1

# ==========================================
# Gateway Load Balancing Configuration
# ==========================================
# Local Multi-instance Configuration (for local development testing of multi-instance scenarios)
# Format: IP:PORT,IP:PORT (multiple instances separated by commas)
# Priority: Nacos Service Discovery > Local Multi-instance Configuration > Single Service Address
HOST_SERVICE_INSTANCES=127.0.0.1:8003
# AUTH_SERVICE_INSTANCES=127.0.0.1:8001,127.0.0.1:8002

# Load Balancing Strategy
# round_robin: Round-robin (default), ensures each instance receives equal request volume
# random: Randomly select instances
# weighted_random: Weighted random selection (requires Nacos to configure instance weights)
LOAD_BALANCE_STRATEGY=round_robin

# ==========================================
# MariaDB Database Configuration
# ==========================================
# MariaDB 10.11 Database Connection Configuration
# Local Development: 127.0.0.1
# Docker Environment: mariadb (container name)
# Remote Server: Server IP or domain name
MARIADB_HOST=127.0.0.1
MARIADB_PORT=3306
MARIADB_USER=intel_user
MARIADB_PASSWORD=intel_***REMOVED***
MARIADB_DATABASE=intel_cw

# ==========================================
# MariaDB SSL/TLS Configuration (Optional)
# ==========================================
# Enable SSL encrypted connection
# true: Enable SSL encrypted transmission
# false: Do not use SSL (default)
MARIADB_SSL_ENABLED=false

# SSL Certificate Configuration (only effective when MARIADB_SSL_ENABLED=true)
# CA Certificate File Path (for validating server certificates)
# It's recommended to provide CA certificate in production environment to ensure connection security
MARIADB_SSL_CA=./infrastructure/mysql/ssl/ca-cert.pem

# Client Certificate File Path (optional, if server requires client certificate authentication)
MARIADB_SSL_CERT=./infrastructure/mysql/ssl/client-cert.pem
MARIADB_SSL_KEY=./infrastructure/mysql/ssl/client-key.pem

# SSL Verification Options
# Whether to verify server certificate
# true: Verify server certificate (recommended for production environment)
# false: Do not verify certificate (development/testing environment, provides encrypted transmission only)
MARIADB_SSL_VERIFY_CERT=true

# Whether to verify server identity (hostname verification)
# true: Verify server hostname matches certificate
# false: Do not verify hostname (default)
MARIADB_SSL_VERIFY_IDENTITY=false

# ==========================================
# Redis Cache Configuration
# ==========================================
# Redis Cache Connection Configuration
# Local Development: 127.0.0.1
# Docker Environment: redis (container name)
# Remote Server: Server IP or domain name
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_USERNAME=

# ==========================================
# Redis SSL/TLS Configuration (Optional)
# ==========================================
# Enable SSL encrypted connection
# true: Enable SSL encrypted transmission (using rediss:// protocol)
# false: Do not use SSL (default, using redis:// protocol)
REDIS_SSL_ENABLED=false

# SSL Certificate Configuration (only effective when REDIS_SSL_ENABLED=true)
# CA Certificate File Path (for validating server certificates)
# It's recommended to provide CA certificate in production environment to ensure connection security
REDIS_SSL_CA=./infrastructure/redis/ssl/ca-cert.pem

# Client Certificate File Path (optional, if server requires client certificate authentication)
REDIS_SSL_CERT=./infrastructure/redis/ssl/client-cert.pem
REDIS_SSL_KEY=./infrastructure/redis/ssl/client-key.pem

# SSL Verification Options
# Whether to verify server certificate
# none: Do not verify certificate (development/testing environment, provides encrypted transmission only)
# optional: Optional verification
# required: Verify server certificate (recommended for production environment)
REDIS_SSL_VERIFY_CERT=none

# Whether to verify server identity (hostname verification)
# true: Verify server hostname matches certificate
# false: Do not verify hostname (default)
REDIS_SSL_VERIFY_IDENTITY=false


# ==========================================
# Nacos Service Discovery Configuration
# ==========================================
# Nacos Server Address and Authentication Information
# Local Development: http://127.0.0.1:8848
# Docker Environment: http://nacos:8848 or http://172.20.0.12:8848
NACOS_SERVER_ADDR=http://localhost:8848
NACOS_PORT=8848
NACOS_USERNAME=nacos
NACOS_PASSWORD=nacos

# Nacos Namespace and Group Configuration
NACOS_NAMESPACE=public
NACOS_GROUP=DEFAULT_GROUP

# Nacos Authentication Token (Base64 encoded 32-byte key, optional)
# NACOS_AUTH_TOKEN=VGhpc0lzQVNlY3JldEtleUZvck5hY29zQXV0aEF0TGVhc3QzMkJ5dGVz

# ==========================================
# JWT Authentication Configuration
# ==========================================
# JWT Key and Token Configuration
# Note: Strong keys must be used in production environment, at least 32 characters recommended
JWT_SECRET_KEY=your-secret-key-change-this-in-production
JWT_ALGORITHM=HS256

# JWT Token Expiration Time Configuration
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# ==========================================
# AES Encryption Configuration
# ==========================================
# AES-256 Encryption Key (for encrypting sensitive data such as host ***REMOVED***words)
# Note: 32-byte key must be used in production environment
# If key length is insufficient, the system will automatically derive using PBKDF2
AES_ENCRYPTION_KEY=your_secure_32_byte_key_here_1234567890123456

# ==========================================
# Jaeger Distributed Tracing Configuration
# ==========================================
# Jaeger Tracing Endpoint Configuration
# gRPC Endpoint (recommended, better performance)
# Local Development: 127.0.0.1:4317
# Docker Environment: jaeger:4317
JAEGER_ENDPOINT_HOST=jaeger:4317

# HTTP Endpoint (backup)
# Local Development: http://localhost:14268/api/traces
# Docker Environment: http://jaeger:14268/api/traces
JAEGER_ENDPOINT=http://localhost:14268/api/traces

# ==========================================
# Prometheus Monitoring Configuration
# ==========================================
# Prometheus Push Gateway Address (for pushing metrics)
# Local Development: http://localhost:9091
# Docker Environment: http://prometheus:9091
PROMETHEUS_PUSH_GATEWAY=http://localhost:9091

# ==========================================
# External Service API Configuration
# ==========================================
# Hardware Service API Address
# External service for host hardware configuration synchronization
HARDWARE_API_URL=http://localhost:8080

# ==========================================
# Logging Configuration
# ==========================================
# Log Level (DEBUG, INFO, WARNING, ERROR, CRITICAL)
LOG_LEVEL=INFO

# ==========================================
# File Upload Configuration
# ==========================================
# File Upload Directory
# Windows Example: C:\Users\YourName\Downloads\uploads
# macOS/Linux Example: /Users/YourName/Downloads/uploads
FILE_UPLOAD_DIR=./uploads

# ==========================================
# Component Switch Configuration
# ==========================================
# These switches control whether to enable corresponding component functions
# In local development environment, some components can be disabled to improve startup speed

# Nacos Service Discovery Switch
# true: Enable Nacos service discovery and registration
# false: Disable Nacos (use static configuration or local multi-instance configuration)
ENABLE_NACOS=false

# Jaeger Distributed Tracing Switch
# true: Enable Jaeger distributed tracing
# false: Disable Jaeger (improve performance, reduce overhead)
ENABLE_JAEGER=false

# Prometheus Monitoring Metrics Switch
# true: Enable Prometheus metrics collection
# false: Disable Prometheus (reduce performance overhead)
ENABLE_PROMETHEUS=false

# ==========================================
# Hardware Interface Mock Configuration
# ==========================================
# Whether to use Mock hardware interface (development/testing environment)
# true: Use Mock data, do not call real hardware interface
# false: Call real hardware interface
USE_HARDWARE_MOCK=true

# ==========================================
# Email Configuration (SMTP)
# ==========================================
# Used to send notification emails (e.g., host approval notifications)
# SMTP Server Configuration
SMTP_SERVER=smtp.example.com
SMTP_PORT=25
# SMTP_PORT=587  # TLS/STARTTLS Port
# SMTP_PORT=465  # SSL Port

# SMTP Authentication Information
SMTP_USER=your_email@example.com
SMTP_PASSWORD=your_email_***REMOVED***word

# Sender Email Address
SMTP_FROM_EMAIL=your_email@example.com

# ==========================================
# Service Instance ID (Optional)
# ==========================================
# Unique identifier for each service instance (for WebSocket cross-instance communication)
# If not set, the system will auto-generate (service name + random suffix)
# SERVICE_INSTANCE_ID=host-service-instance-1

# ==========================================
# Database Connection Pool Configuration (Advanced Configuration, Optional)
# ==========================================
# Database Connection Pool Size (default is determined by service configuration)
# DB_POOL_SIZE=300
# DB_MAX_OVERFLOW=500

# ==========================================
# HTTP Client Configuration (Advanced Configuration, Optional)
# ==========================================
# HTTP Request Timeout Configuration (seconds)
# HTTP_TIMEOUT=15.0
# HTTP_CONNECT_TIMEOUT=5.0
# HTTP_MAX_KEEPALIVE_CONNECTIONS=20
# HTTP_MAX_CONNECTIONS=100

# ==========================================
# Health Check Configuration (Advanced Configuration, Optional)
# ==========================================
# Health Check Timeout Configuration (seconds)
# HEALTH_CHECK_TIMEOUT=5.0
# HEALTH_CHECK_CONNECT_TIMEOUT=2.0
