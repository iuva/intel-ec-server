# ==========================================
# Intel EC 微服务架构 - 环境变量配置示例
# ==========================================
# 
# 使用说明：
# 1. 复制此文件为 .env: cp .env.example .env
# 2. 根据实际环境修改配置值
# 3. 生产环境请使用强密码和密钥
# 4. 不要将 .env 文件提交到版本控制系统
#
# ==========================================

# ==========================================
# 数据库配置 (MariaDB 10.11)
# ==========================================
# MariaDB 数据库连接配置
# 注意：生产环境请使用强密码
MARIADB_ROOT_PASSWORD=mariadb123
MARIADB_DATABASE=intel_cw
MARIADB_USER=intel_user
MARIADB_PASSWORD=intel_***REMOVED***
MARIADB_PORT=3306
MARIADB_HOST=mariadb

# ==========================================
# Redis 配置
# ==========================================
# Redis 缓存连接配置
# 注意：生产环境请设置强密码
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_USERNAME=

# ==========================================
# Nacos 服务发现配置
# ==========================================
# Nacos 服务器地址和认证信息
# 注意：NACOS_AUTH_TOKEN 必须是 Base64 编码的 32 字节密钥
NACOS_SERVER_ADDR=http://nacos:8848
NACOS_PORT=8848
NACOS_USERNAME=nacos
NACOS_PASSWORD=nacos
NACOS_NAMESPACE=public
NACOS_GROUP=DEFAULT_GROUP
NACOS_AUTH_TOKEN=VGhpc0lzQVNlY3JldEtleUZvck5hY29zQXV0aEF0TGVhc3QzMkJ5dGVz

# ==========================================
# Jaeger 分布式追踪配置
# ==========================================
# Jaeger 追踪端点配置
# 注意：使用 gRPC 端点（4317）而不是 HTTP 端点（4318）
JAEGER_ENDPOINT=jaeger:4317

# ==========================================
# JWT 认证配置
# ==========================================
# JWT 密钥和令牌配置
# 注意：生产环境必须使用强密钥，建议至少 32 字符
JWT_SECRET_KEY=default_secret_key
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# ==========================================
# AES 加密配置
# ==========================================
# AES-256 加密密钥（用于主机密码加密）
# 注意：生产环境必须使用 32 字节密钥
# 如果密钥长度不足，系统会自动使用 PBKDF2 派生
AES_ENCRYPTION_KEY=default_aes_key_32_bytes_long_0123456789

# ==========================================
# 服务基础配置
# ==========================================
# 服务名称和端口配置
# 注意：SERVICE_IP 在 Docker 环境中会自动设置，本地环境可以使用 127.0.0.1

# Gateway Service (API网关)
SERVICE_NAME=gateway-service
SERVICE_PORT=8000
GATEWAY_SERVICE_PORT=8000
SERVICE_IP=172.20.0.100
GATEWAY_SERVICE_NAME=gateway-service

# Auth Service (认证服务)
AUTH_SERVICE_NAME=auth-service
AUTH_SERVICE_PORT=8001

# Host Service (主机服务)
HOST_SERVICE_NAME=host-service
HOST_SERVICE_PORT=8003

# 服务发现配置（用于服务间通信）
SERVICE_HOST_AUTH=auth-service
SERVICE_HOST_HOST=host-service

# ==========================================
# 外部服务 API 配置
# ==========================================
# 外部硬件服务 API 地址
HARDWARE_API_URL=http://hardware-service:8000

# ==========================================
# Grafana 配置
# ==========================================
# Grafana 管理员密码
# 注意：生产环境请使用强密码
GRAFANA_ADMIN_PASSWORD=***REMOVED***

# ==========================================
# 应用配置
# ==========================================
# 应用运行环境配置
ENVIRONMENT=production
DEBUG=false
LOG_LEVEL=INFO

# .env 自动加载配置
AUTO_LOAD_DOTENV=false

# ==========================================
# WebSocket 配置（测试环境）
# ==========================================
# WebSocket 连接 URL（仅用于测试）
# WEBSOCKET_URL=ws://localhost:8003

# ==========================================
# 注意事项
# ==========================================
# 1. 生产环境配置：
#    - 修改所有默认密码为强密码
#    - 修改 JWT_SECRET_KEY 为随机生成的强密钥
#    - 修改 AES_ENCRYPTION_KEY 为 32 字节密钥
#    - 设置 DEBUG=false
#    - 设置 ENVIRONMENT=production
#
# 2. 开发环境配置：
#    - 可以使用默认配置
#    - 设置 DEBUG=true 以启用调试模式
#    - 设置 ENVIRONMENT=development
#
# 3. 安全建议：
#    - 不要将 .env 文件提交到 Git
#    - 定期更换密钥和密码
#    - 使用密钥管理服务（如 AWS Secrets Manager）
#    - 限制 .env 文件访问权限
#
# 4. Docker 环境说明：
#    - SERVICE_IP 会自动设置，无需手动配置
#    - MARIADB_HOST 和 REDIS_HOST 在 Docker 网络中会自动解析
#    - 本地开发时，请使用 localhost 或 127.0.0.1
#
# ==========================================
