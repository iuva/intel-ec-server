# ==========================================
# Intel EC 微服务项目环境变量配置示例
# ==========================================
# 复制此文件为 .env 并修改为您的实际配置
# cp .env.example .env

# ==========================================
# MySQL 数据库配置（外部服务）
# ==========================================
# MySQL 主机地址（如果在本机，使用 host.docker.internal 或实际IP）
MARIADB_HOST=localhost
# MySQL 端口
MARIADB_PORT=3306
# MySQL 用户名
MARIADB_USER=root
# MySQL 密码
MARIADB_PASSWORD=your_mysql_***REMOVED***word
# MySQL 数据库名
MARIADB_DATABASE=intel_cw

# ==========================================
# Redis 缓存配置（外部服务）
# ==========================================
# Redis 主机地址（如果在本机，使用 host.docker.internal 或实际IP）
REDIS_HOST=localhost
# Redis 端口
REDIS_PORT=6379
# Redis 密码（如果没有密码，留空）
REDIS_PASSWORD=
# Redis 数据库编号（默认为0，不同服务使用不同的DB）
REDIS_DB=0

# ==========================================
# JWT 安全配置
# ==========================================
# JWT 密钥（生产环境请使用强密码，至少32个字符）
JWT_SECRET_KEY=your-super-secret-jwt-key-change-in-production-min-32-chars

# ==========================================
# Nacos 服务发现配置
# ==========================================
# Nacos 认证令牌（必须是Base64编码的32字节密钥）
# 默认值解码后为: "ThisIsASecretKeyForNacosAuthAtLeast32Bytes"
# 生产环境请生成新的密钥：echo -n "your-secret-key-at-least-32-bytes" | base64
NACOS_AUTH_TOKEN=VGhpc0lzQVNlY3JldEtleUZvck5hY29zQXV0aEF0TGVhc3QzMkJ5dGVz

# ==========================================
# 应用配置
# ==========================================
# 调试模式（生产环境设置为 false）
DEBUG=false
# 日志级别（DEBUG, INFO, WARNING, ERROR, CRITICAL）
LOG_LEVEL=INFO

# ==========================================
# 监控配置
# ==========================================
# Grafana 管理员密码
GRAFANA_ADMIN_PASSWORD=***REMOVED***

# ==========================================
# 网络配置说明
# ==========================================
# 如果 MySQL 和 Redis 运行在宿主机上：
#   - macOS/Windows: 使用 host.docker.internal
#   - Linux: 使用宿主机的实际IP地址（如 192.168.1.100）
#
# 如果 MySQL 和 Redis 运行在其他 Docker 容器中：
#   - 使用容器名称或容器IP地址
#
# 示例配置：
# MYSQL_HOST=host.docker.internal  # macOS/Windows 宿主机
# MYSQL_HOST=192.168.1.100         # Linux 宿主机或远程服务器
# REDIS_HOST=host.docker.internal  # macOS/Windows 宿主机
# REDIS_HOST=192.168.1.100         # Linux 宿主机或远程服务器
