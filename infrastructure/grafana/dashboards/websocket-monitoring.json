        "showThresholdLabels": false,
        "showThresholdMarkers": true
      },
      "pluginVersion": "8.0.0",
      "targets": [
        {
          "expr": "sum(websocket_connections_active{service=~\"$service\"})",
          "interval": "",
          "legendFormat": "活跃连接数",
          "refId": "A"
        }
      ],
      "title": "活跃 WebSocket 连接",
      "type": "gauge"
